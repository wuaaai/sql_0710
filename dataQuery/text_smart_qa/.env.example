# ============================================================
# 环境配置文件模板（可提交到 Git）
# 复制此文件为 .env 后填入真实值，或使用 switch_env.py 切换环境
# ============================================================

# ---------- LLM API 密钥 ----------
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
QWEN_API_KEY=sk-Local
QWEN_BASE_URL=http://localhost:18000/v1
LANGSMITH_API_KEY=your-langsmith-api-key
ZHIPUAI_API_KEY=your-zhipuai-api-key
TavilyClient_API_KEY=your-tavily-api-key

# ---------- LLM 模型参数 ----------
LLM_MODEL_NAME=deepseek-chat
LLM_TEMPERATURE=0.5
LLM_TRIMMER_MAX_TOKENS=8000
LLM_TOKEN_COUNTER=approximate
LLM_TRIMMER_STRATEGY=last

# ---------- 向量数据库 (PostgreSQL pgvector) ----------
PGVECTOR_CONNECTION=postgresql+psycopg2://postgres:123456@localhost:5432/postgres
PGVECTOR_COLLECTION_NAME=parent_child_db_1024

# ---------- Embedding / Rerank 服务 ----------
EMBEDDING_API_URL=http://localhost:8991/embed
EMBEDDING_API_KEY=
EMBEDDING_MODEL_NAME=
RERANK_API_URL=http://localhost:8991/rerank
RERANK_API_KEY=
RERANK_MODEL_NAME=

# ---------- 图片服务 ----------
IMAGE_BASE_URL=http://localhost:8000/static/images/

# ---------- FastAPI 服务 ----------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ALLOW_ORIGINS=*

# ---------- 记忆管理 ----------
MEMORY_TOKEN_LIMIT=13000
MAX_USER_MESSAGES=10
TOKENIZER_MODEL=gpt-3.5-turbo

# ---------- 工具调用限制 ----------
RAG_MAX_CALLS=4
AGENT_RUN_LIMIT=20

# ---------- 日志 ----------
LOG_LEVEL=DEBUG
LOG_ROTATION=10 MB
LOG_RETENTION=10 days

# ---------- 时区 ----------
TIMEZONE=Asia/Shanghai

# ---------- Python 路径 ----------
PYTHONPATH=src
